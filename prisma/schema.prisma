generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("user")
  createdAt DateTime @default(now())
  cart      Cart?
  orders    Order[]

  @@map("users")
}

model Product {
  id          String      @id @default(cuid())
  name        String
  description String?
  price       Int
  stock       Int         @default(0)
  category    String?
  imageUrl    String?
  createdAt   DateTime    @default(now())
  isHidden    Boolean     @default(false)
  updatedAt   DateTime    @updatedAt
  cartItems   CartItem[]
  orderItems  OrderItem[]

  @@map("products")
}

model SystemCode {
  id         String  @id @default(cuid())
  groupCode  String
  groupLabel String
  code       String  @unique
  label      String
  sortOrder  Int     @default(0)
  orders     Order[]

  @@map("system_codes")
}

model Order {
  id            String      @id @default(cuid())
  userId        String
  statusCodeId  String
  receiverName  String
  receiverPhone String
  address       String
  totalPrice    Int
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  orderItems    OrderItem[]
  status        SystemCode  @relation(fields: [statusCodeId], references: [id])
  user          User        @relation(fields: [userId], references: [id])

  @@map("orders")
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Int
  order     Order   @relation(fields: [orderId], references: [id])
  product   Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique
  createdAt DateTime   @default(now())
  cartItems CartItem[]
  user      User       @relation(fields: [userId], references: [id])

  @@map("carts")
}

model CartItem {
  id        String  @id @default(cuid())
  cartId    String
  productId String
  quantity  Int
  cart      Cart    @relation(fields: [cartId], references: [id])
  product   Product @relation(fields: [productId], references: [id])

  @@unique([cartId, productId])
  @@map("cart_items")
}
